{
  "name": "Lucidbloom",
  "description": "A psychedelic dark design system for editorial, music, and lifestyle products that lean on saturated imagery, liquid gradients, and hand-drawn cosmic ornamentation.",
  "theme": "dark",
  "concept": "Lucidbloom translates 1970s blacklight posters and modern liquid-marble renders into a cohesive product surface. Layered translucent panels float over a deep violet void, while marigold, magenta, and cyan accents bloom through the interface like ink in water. Imagery, ornament, and type all share one velvet, hand-drawn, slightly trippy grammar.",
  "palette": [
    {
      "name": "Cosmic Void",
      "value": "#0E0322",
      "role": "Primary page background — the deep violet-black behind every surface."
    },
    {
      "name": "Velvet Nebula",
      "value": "#1F0A4A",
      "role": "Raised surface tone for cards, panels, and modals."
    },
    {
      "name": "Iris Bloom",
      "value": "#7E3BFF",
      "role": "Primary action color, focus rings, and active tab indicator."
    },
    {
      "name": "Aurora Magenta",
      "value": "#FF2BB1",
      "role": "Secondary accent for highlights, badges, and gradient stops."
    },
    {
      "name": "Solar Flare",
      "value": "#FF8A2A",
      "role": "Warm accent for CTAs, illustrative glow, and warning chips."
    },
    {
      "name": "Halo Citrine",
      "value": "#FFD23F",
      "role": "Pop accent for ornaments, decorative dots, and success states."
    },
    {
      "name": "Mycelia Teal",
      "value": "#29E5C9",
      "role": "Cool accent for links, micro-icons, and counter-balance to magenta."
    },
    {
      "name": "Lucid Ink",
      "value": "#FBF5FF",
      "role": "Primary readable foreground text on dark surfaces."
    }
  ],
  "fonts": [
    {
      "name": "Bagel Fat One",
      "provider": "Google Fonts",
      "usage": "Display headlines, hero numerals, and decorative wordmark moments.",
      "cssImport": "https://fonts.googleapis.com/css2?family=Bagel+Fat+One&display=swap"
    },
    {
      "name": "Outfit",
      "provider": "Google Fonts",
      "usage": "Body copy, UI labels, navigation, and form controls.",
      "cssImport": "https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
    }
  ],
