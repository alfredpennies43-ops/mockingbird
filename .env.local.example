# Resend — pick ONE setup:
#
# A) Test now (no domain verification):
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=onboarding@resend.dev
# (Only delivers to the email you used to sign up for Resend)
#
# B) Production (after verifying mockingbird.ai in Resend):
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=songs@mockingbird.ai
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Mureka
MUREKA_API_KEY=

# App — use your stable Vercel production domain (not a deployment hash URL)
